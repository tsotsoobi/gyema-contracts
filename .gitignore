*.wasm
*.optimized.wasm

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment files (just in case)
.env
.env.local
.env.*.local

# OS junk
Thumbs.db
desktop.ini

# Coverage / profiling
*.profraw
coverage/
tarpaulin-report.html

# Soroban deployment artifacts (not committed; deployment-environment-specific)
.soroban/
soroban.toml

# Stellar key files — never commit
*.key
*.secret
identity/
